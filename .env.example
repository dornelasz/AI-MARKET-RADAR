# ---- Database ----
# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://radar:radar@localhost:5432/ai_market_radar?schema=public"

# ---- AI (optional) ----
# If GEMINI_API_KEY is empty the app still runs: articles stay PENDING_ANALYSIS.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
AI_ANALYSIS_ENABLED=true
AI_BATCH_SIZE=5
AI_ANALYSIS_DAILY_LIMIT=50
# When a Gemini quota/rate limit is hit, stop the batch safely (recommended).
AI_ANALYSIS_STOP_ON_RATE_LIMIT=true
# Suggested cooldown (minutes) before retrying after a Gemini limit.
AI_ANALYSIS_RETRY_COOLDOWN_MINUTES=60

# ---- Collection worker ----
FETCH_INTERVAL_MINUTES=15

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
